# tireops environment variables
# -------------------------------------------------------------
# Copy this file to .env.local and fill in real values. The
# .env* pattern is in .gitignore so .env.local will never be
# committed. Don't share screenshots of .env.local on a stream —
# that's how keys leak.

# ---- Supabase ----------------------------------------------
# Both come from the Supabase project dashboard:
#   Project Settings → API → "URL" and "anon public" key.
# The anon key is safe to expose in client bundles (it's gated
# by Row Level Security policies). Don't paste the service_role
# key here — tireops doesn't use it.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ---- Anthropic (Claude) -------------------------------------
# Powers the chat agent and the CRM-integration endpoint.
# Get one at: https://console.anthropic.com → API Keys.
# Required.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---- OpenAI (Whisper + TTS) ---------------------------------
# Used by /api/transcribe (speech-to-text) and /api/speak
# (text-to-speech). Without this the mic button still uploads
# but you'd see transcribe errors.
# Get one at: https://platform.openai.com → API Keys.
# Required for voice features; the rest of the app works
# without it.
OPENAI_API_KEY=sk-proj-...

# ---- CRM ↔ tireops integration -----------------------------
# Shared secret between this app and the sibling BuySellTires
# CRM. When the CRM POSTs to /api/integration/inventory it
# sends this value in the X-Inventory-Token header. Generate
# any long random string — `openssl rand -hex 32` is fine —
# and put the same value in the CRM's env as TIREOPS_API_TOKEN.
# See docs/decisions/0001-crm-integration-auth.md for the why.
# Required if you want the integration endpoint to work; the
# rest of the app runs fine without it.
CRM_INTEGRATION_TOKEN=

# ---- AI spend safety (optional) ----------------------------
# Daily cap on Anthropic spend in USD. Once today's usage
# exceeds this, /api/chat returns HTTP 429 until UTC midnight.
# Default is $5/day if unset. Raise for high-volume days,
# lower for tight testing.
# Override:
# DAILY_AI_BUDGET_USD=5.00

# Emergency bypass — set to the literal string "true" to
# disable the budget check entirely. Use sparingly; the cap
# exists because a $28 surprise bill happened to the sibling
# CRM and nobody wants it again.
# AI_BUDGET_DISABLED=false
